# 数据库路径（默认：data/sequoia_v2.db）
DB_PATH=data/sequoia_v2.db

# 数据起始日期（默认：2024-01-01）
START_DATE=2026-01-01

# 默认飞书 Webhook URL（必填，作为 fallback）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-default-token

# 策略专属 Webhook（可选）
# 格式：STRATEGY_WEBHOOK_<策略标识>=<URL>
STRATEGY_WEBHOOK_MA_VOLUME=https://open.feishu.cn/open-apis/bot/v2/hook/your-ma-volume-token
STRATEGY_WEBHOOK_TURTLE=https://open.feishu.cn/open-apis/bot/v2/hook/your-turtle-token
STRATEGY_WEBHOOK_FLAG=https://open.feishu.cn/open-apis/bot/v2/hook/your-flag-token
STRATEGY_WEBHOOK_SHAKEOUT=https://open.feishu.cn/open-apis/bot/v2/hook/your-shakeout-token
STRATEGY_WEBHOOK_LIMIT_DOWN=https://open.feishu.cn/open-apis/bot/v2/hook/your-limit-down-token
STRATEGY_WEBHOOK_RPS=https://open.feishu.cn/open-apis/bot/v2/hook/your-rps-token
STRATEGY_WEBHOOK_PRIVATE_PLACEMENT=https://open.feishu.cn/open-apis/bot/v2/hook/your-private-placement-token
STRATEGY_WEBHOOK_MONEY_FLOW=https://open.feishu.cn/open-apis/bot/v2/hook/your-money-flow-token
STRATEGY_WEBHOOK_NORTH_BOUND=https://open.feishu.cn/open-apis/bot/v2/hook/your-north-bound-token
STRATEGY_WEBHOOK_INSTITUTIONAL=https://open.feishu.cn/open-apis/bot/v2/hook/your-institutional-token
# 新增 8 策略
STRATEGY_WEBHOOK_PE_ROE=https://open.feishu.cn/open-apis/bot/v2/hook/your-pe-roe-token
STRATEGY_WEBHOOK_EARNINGS_SURPRISE=https://open.feishu.cn/open-apis/bot/v2/hook/your-earnings-surprise-token
STRATEGY_WEBHOOK_TREND_MOMENTUM=https://open.feishu.cn/open-apis/bot/v2/hook/your-trend-momentum-token
STRATEGY_WEBHOOK_NORTH_BOUND_MONEY=https://open.feishu.cn/open-apis/bot/v2/hook/your-north-bound-money-token
STRATEGY_WEBHOOK_HIGH_DIVIDEND=https://open.feishu.cn/open-apis/bot/v2/hook/your-high-dividend-token
STRATEGY_WEBHOOK_SECTOR_ROTATION=https://open.feishu.cn/open-apis/bot/v2/hook/your-sector-rotation-token
STRATEGY_WEBHOOK_VOLUME_DRAWDOWN=https://open.feishu.cn/open-apis/bot/v2/hook/your-volume-drawdown-token
STRATEGY_WEBHOOK_FUNDAMENTAL_MULTIFACTOR=https://open.feishu.cn/open-apis/bot/v2/hook/your-fundamental-multifactor-token
STRATEGY_WEBHOOK_SECTOR_MOMENTUM=https://open.feishu.cn/open-apis/bot/v2/hook/your-sector-momentum-token

# ── Tushare 配置（唯一数据源）──
# Tushare API Token（必填，注册地址：https://tushare.pro）
TUSHARE_TOKEN=your_tushare_token_here
# Tushare 代理地址（可选，避开 IP 白名单限制）
TUSHARE_PROXY_URL=http://8.148.76.181:8686/
